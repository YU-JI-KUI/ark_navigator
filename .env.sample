# ==============================================================================
# Ark Navigator 环境变量配置模板
# ==============================================================================
# 使用方法：
#   1. 复制本文件：cp .env.sample .env
#   2. 把 your_xxx 占位值替换为真实配置
#   3. 启动服务时由 dotenv 自动加载
#
# 标记说明：
#   🔐  敏感（密钥/凭证），不要提交真实值到代码仓库
#   ⚠️  有坑（命名易混淆 / 已知问题），看完注释再配置
#   📝  详见 src/ark_nav/docs/ENV_INVENTORY.md
#
# 上次整理：2026-05-10（Kris 接手项目时）
#   - 删除 9 个死配置（代码完全没读取）
#   - 补充 5 个隐藏配置（代码在读但 sample 之前未声明）
# ==============================================================================


# ==============================================================================
# [1] 平安大模型 API（寿险主链路核心）
# ==============================================================================
# OPEN_AI_URL：LLM 网关地址（公司内网）
OPEN_AI_URL=http://eagw-gateway-sf.paic.com.cn:80/pingan/bigModel/api/v1/chat/completions

# 🔐 RSA 私钥，用于 open_ai_signature 中的 RSA SHA256 签名
RSA_PK=your_rsa_private_key

# 🔐 寿险大模型的 app_key / app_secret（HMAC-SHA1 签名用）
APP_KEY=your_app_key
APP_SECRET=your_app_secret

# 🔐 凭证 ID 与开放接口编码
CRE_ID=your_cre_id
OPEN_API_CODE=your_open_api_code

# 寿险意图识别的场景 ID（不同 scene_id 对应不同微调模型）
SCENE_ID=your_scene_id


# ==============================================================================
# [2] 意图重写模型（白泽，用于 Advance / CoT 策略）
# ==============================================================================
INTENT_REWRITE_SCENE_ID=your_intent_rewrite_scene_id
# 🔐
INTENT_REWRITE_APP_KEY=your_intent_rewrite_app_key
# 🔐
INTENT_REWRITE_APP_SECRET=your_intent_rewrite_app_secret


# ==============================================================================
# [3] 养老险大模型
# ==============================================================================
YLX_LLM_SCENE_ID=your_ylx_llm_scene_id
# 🔐
YLX_LLM_APP_KEY=your_ylx_llm_app_key
# 🔐
YLX_LLM_APP_SECRET=your_ylx_llm_app_secret


# ==============================================================================
# [4] 体验评估模型（仅 CoT 策略 intent_classifier_cot.py 使用）
# ==============================================================================
EXP_SCENE_ID=your_exp_scene_id
# 🔐
EXP_APP_KEY=your_exp_app_key
# 🔐
EXP_APP_SECRET=your_exp_app_secret


# ==============================================================================
# [5] 智能体平台（FAQ 知识库 + Prompt 拉取）
# ==============================================================================
AGENT_PLATFORM_HOST=https://sa-agents-gateway-stg1.paic.com.cn
AGENT_PLATFORM_TOKEN_URL=/appid/auth/login
AGENT_PLATFORM_RAG_QUERY_URL=/api/open/kn/knSearch
AGENT_PLATFORM_RAG_FAQ_PAGE_URL=/api/open/kn/faq/page
AGENT_PLATFORM_RAG_FAQ_PAGE_SIMILAR_URL=/api/open/kn/faq/pageSimilar
AGENT_PLATFORM_RAG_FAQ_TABLE_DETAIL_URL=/api/open/kn/v2/tableDetailList
AGENT_PLATFORM_RAG_FAQ_TABLE_LIST_URL=/api/open/kn/tableList

AGENT_PLATFORM_APP_ID=your_agent_platform_app_id
# 🔐
AGENT_PLATFORM_APP_SECRET=your_agent_platform_app_secret


# ==============================================================================
# [6] 知识库 ID（KG_ID）
# ==============================================================================
# ⚠️ 命名分裂：寿险有 SHOUXIAN_ 前缀，养老险没有 YLX_ 前缀（详见 docs/ENV_INVENTORY.md BUG-8）
# 第一轮整改不改名（属于改逻辑，需同步部署侧），此处仅标注。

# 寿险知识库 ID
SHOUXIAN_AGENT_PLATFORM_KG_ID=your_shouxian_agent_platform_kg_id

# 养老险知识库 ID（变量名无前缀，注意别和寿险混淆）
AGENT_PLATFORM_KG_ID=your_agent_platform_kg_id


# ==============================================================================
# [7] FAISS / 本地知识库
# ==============================================================================
# FAISS 索引文件目录（运行时按 ${FAISS_INDEX_DIR}/{shouxian,yanglaoxian} 分子目录）
FAISS_INDEX_DIR=./data

# 是否启用本地 KG 检索：True=本地 FAISS，False=远程 RAG
ENABLE_LOCAL_KG=False


# ==============================================================================
# [8] ESG 小安机器人（养老险 OneKeyService 用）
# ==============================================================================
ESG_OAUTH_URL=your_esg_oauth_url
ESG_GRANT_TYPE=client_credentials
# 🔐
ESG_CLIENT_ID=your_esg_client_id
# 🔐
ESG_CLIENT_SECRET=your_esg_client_secret
ESG_XIAOAN_CHAT_ADDR=your_esg_xiaoan_chat_addr

# Token 有效期（天）。⚠️ 寿险红利渠道(下方[9])也复用这个变量
ESG_TOKEN_EXPIRY=30

# 小安机器人知识库 ID（int 类型）
XIAOAN_REPOSITORY_ID=your_xiaoan_repository_id


# ==============================================================================
# [9] ESG 寿险红利渠道（shouxian_nav_service.py 用）
# ==============================================================================
# ⚠️ 这一组与 [8] 是两套独立的 ESG 客户端配置（业务方有意拆分），
#    但 ESG_OAUTH_URL 和 ESG_TOKEN_EXPIRY 与 [8] 共用同一变量。

ESG_GRANT_TYPE_4_BONUS=client_credentials
# 🔐
ESG_CLIENT_ID_4_BONUS=your_esg_client_id_4_bonus
# 🔐
ESG_CLIENT_SECRET_4_BONUS=your_esg_client_secret_4_bonus
ESG_BONUS_CHAT_ADDR=your_esg_bonus_chat_addr


# ==============================================================================
# [10] 日志脱敏（2026-05 新增）
# ==============================================================================
# 是否启用日志层敏感信息自动脱敏（手机号 / 身份证 / 邮箱 / 银行卡 / 地址 5 类正则
# + 敏感字段名 [REDACTED] 替换）。规则定义在 src/ark_nav/core/utils/masking_rules.py。
#
# 1 = 启用（默认，金融场景必须）
# 0 = 关闭（仅在确认正则误伤需要快速回滚时使用）
LOG_MASK_ENABLED=1


# ==============================================================================
# [11] Ray Serve 部署配置
# ==============================================================================
# 各 Deployment 的最小副本数 / 初始副本数
# 实际值在 nav_agent.py / intent_classify_agent.py / ark_nav_api.py / bert.py / rag_models.py 各自有默认值
RAY_MIN_REPLICAS=1
RAY_INITIAL_REPLICAS=1


# ==============================================================================
# [12] 定时任务（scripts/scheduled_knowledge_sync.py）
# ==============================================================================
# ⚠️ 下面两个变量名只差三个字母，但语义完全不同！

# 每日触发时间（24h 制 HH:MM 格式），如 21:30 表示每天晚上 21:30 执行
RAG_EXECUTION_TIME=21:30

# HTTP 调用超时秒数。⚠️ 详见 docs/ENV_INVENTORY.md BUG-6：
# scheduled_knowledge_sync.py:23 的代码写法 int(os.getenv("RAG_EXECUTION_TIMEOUT"), 600)
# 把 600 当成进制 base 而非默认值，未配置时会直接抛 TypeError，必须显式配置
RAG_EXECUTION_TIMEOUT=600


# ==============================================================================
# [13] 由智能体平台运行时拉取的 Prompt（不需要在部署时手动配置）
# ==============================================================================
# 这三个变量的值是由 init_prompt_from_agent_rag() 在运行时从智能体平台
# 通过 _get_prompt_by_name() 拉取后写入 os.environ 的（详见 xiezhi_http.py:104-121）。
#
# 如果智能体平台不可达 / refresh_prompt 接口未被调用，下游读取会得到 None。
# 一般不需要手动配置；如要本地调试可以临时填入。
#
# XIEZHI_PROMPT=         # 寿险意图识别 prompt（对应智能体平台名称：服务意图识别）
# BAIZE_PROMPT=          # 寿险意图重写 prompt（对应智能体平台名称：白泽意图重写）
# YLX_PROMPT=            # 养老险意图识别 prompt（对应智能体平台名称：养老险意图识别）


# ==============================================================================
# 已删除的配置（仅作记录，不要再加回来）
# ==============================================================================
# 以下变量曾经在 .env.sample 中存在，但因死配置或功能砍除已删除。
# 如有需要请先在代码中实际使用，再加回 sample。
#
# --- 2026-05-10 第一轮整理：代码完全没读取的死配置（9 个） ---
#   APP_HOST                       # 代码无引用
#   APP_PORT                       # 代码无引用（端口走 Settings.port 默认值 8080）
#   ENVIRONMENT                    # 代码无引用
#   NEW_RELIC_CONFIG_FILE          # 代码无引用
#   DETECTOR_AGENT_ID              # 代码无引用
#   DETECTOR_COLLECTOR_IP          # 代码无引用
#   caas_logs_app                  # 代码无引用
#   AGENT_PLATFORM_KG_ID_YLX       # 代码无引用（养老险实际用的是 AGENT_PLATFORM_KG_ID）
#   ESG_TOKEN_EXPIRY_4_BONUS       # 代码无引用（红利路径复用了 ESG_TOKEN_EXPIRY）
#
# --- 2026-05-10 砍除 DataPusherService 数据回流功能 ---
#   DATAPULSE_URL                  # 随 data_pusher_service.py 一起删除
